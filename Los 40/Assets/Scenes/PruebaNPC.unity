    1\",\"OptionUIDs\":null,\"SpeechUID\":0,\"TimeUntilAdvance\":2,\"Volume\":0},{\"Connections\":[{\"__type\":\"EditableSpeechConnection:#DialogueEditor\",\"Conditions\":[],\"NodeUID\":12}],\"EditorInfo\":{\"isRoot\":false,\"xPos\":459,\"yPos\":64},\"ID\":11,\"ParamActions\":[],\"TMPFontGUID\":null,\"Text\":\"Oiga\u2026
